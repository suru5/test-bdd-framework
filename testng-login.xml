<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="saucedemo Login Suite" verbose="2" thread-count="1">

    <parameter name="browser" value="chrome" />

    <listeners>
        <listener class-name="com.framework.utils.TestNGListener" />
    </listeners>

    <!-- All login scenarios (positive + negative) -->
    <test name="saucedemo Login Tests - All Scenarios">
        <classes>
            <class name="com.framework.runners.TestRunner" />
        </classes>
    </test>

</suite>
